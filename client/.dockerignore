# Docker ignore patterns for frontend
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/

# Environment files and secrets
.env
.env.*

# Logs
logs
*.log

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Git
.git
.gitignore

# Docker files
Dockerfile*
docker-compose*
.dockerignore

# Cache directories
.cache/
.parcel-cache/
.vite/

# Runtime data
pids
*.pid
*.seed
*.pid.lock
