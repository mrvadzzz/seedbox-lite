# Required: replace this value before starting the application.
ACCESS_PASSWORD=change-this-password

# Docker ports exposed on the host.
BACKEND_PORT=3001
FRONTEND_PORT=5174
TORRENT_PORT=6881
DHT_PORT=6882

# Backend configuration.
NODE_ENV=production
SERVER_PORT=3001
SERVER_HOST=0.0.0.0
SERVER_PROTOCOL=http
FRONTEND_URL=*
TORRENT_UPLOAD_LIMIT=262144
LOG_LEVEL=1
DEBUG=false

# Leave empty to make the frontend use the hostname from the browser URL.
# Set a full URL only when the API is exposed through another host or domain.
VITE_API_BASE_URL=

# Optional metadata providers. The application works without these keys.
OMDB_API_KEY=
TMDB_API_KEY=
